APP_NAME="School CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=school_crm
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Leave unset on HTTPS — Laravel sets Secure automatically when trustProxies is enabled.
# SESSION_SECURE_COOKIE=

# Super Admin (created by AdminUserSeeder / php artisan crm:ensure-admin)
# Sign in at /admin with ADMIN_MOBILE + ADMIN_PASSWORD
ADMIN_MOBILE=9876543210
ADMIN_PASSWORD=Admin@2026
ADMIN_NAME="Super Admin"

# Hidden vendor console — not for school staff. Set PLATFORM_MOBILE then run: php artisan crm:ensure-platform-operator
PLATFORM_PANEL_PATH=_vendor-console
PLATFORM_MOBILE=
PLATFORM_PASSWORD=ChangeMe@Platform2026
PLATFORM_NAME="Platform Operator"

# Default license on fresh install (vendor can change from console)
LICENSE_DEFAULT_PLAN=full_results
LICENSE_DEFAULT_VALID_DAYS=365

# Student portal default password (mobile + this at /portal/login)
PORTAL_DEFAULT_PASSWORD=Student@2026

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Full CRM backups (database + all uploaded files). Nightly via schedule:run.
CRM_BACKUP_RETAIN=14
CRM_BACKUP_SCHEDULE_AT=02:15
# Optional: Google OAuth for Drive upload (or paste Client ID/Secret in Setup → Backups)
# Redirect URI must be: {APP_URL}/admin/backups/google/callback
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# Attendance auto check-out (APP_TIMEZONE, usually Asia/Kolkata).
ATTENDANCE_AUTO_OUT_ENABLED=true
ATTENDANCE_AUTO_OUT_TIME=20:00
ATTENDANCE_AUTO_OUT_LATE_GRACE_MINUTES=60
# ATTENDANCE_WEEKEND_DAYS=0
# ATTENDANCE_PERCENTAGE_CREDIT_LEAVE=true

# Biometric ADMS (ZKTeco cloud server → this CRM)
BIOMETRIC_ADMS_ENABLED=true
BIOMETRIC_ADMS_REQUIRE_ALLOWLIST=true
BIOMETRIC_ADMS_PROCESS_INLINE=true
# Optional: force ADMS TimeZone in minutes (IST = 330). Auto from APP_TIMEZONE if empty.
# BIOMETRIC_ADMS_TZ_OFFSET_MINUTES=330
# BIOMETRIC_ADMS_TIMEZONE=Asia/Kolkata
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Meta WhatsApp Cloud API (optional — can also set in Setup → Meta WhatsApp)
# META_WHATSAPP_GRAPH_VERSION=v20.0
# META_WHATSAPP_PHONE_NUMBER_ID=
# META_WHATSAPP_WABA_ID=
# META_WHATSAPP_ACCESS_TOKEN=
# META_WHATSAPP_DEFAULT_LANGUAGE=en
# META_WHATSAPP_VERIFY_TOKEN=
# META_WHATSAPP_APP_SECRET=
# META_WHATSAPP_OTP_TEMPLATE_NAME=
# META_WHATSAPP_OTP_TEMPLATE_LANGUAGE=en
# META_WHATSAPP_OTP_INCLUDE_BUTTON=false
# META_WHATSAPP_OTP_TTL_SECONDS=300

# Institute branding — optional fallbacks only; configure in admin (Website → Site Content, Setup wizard).
# INSTITUTE_NAME, INSTITUTE_PHONE, etc. are NOT required for normal use.
# INSTITUTE_TYPE=school
# SEED_DEMO_DATA=false
# FEE_PAYMENT_ALLOCATION=auto
